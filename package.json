{
  "name": "ai-onchain-intent-agent-protocol",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered on-chain agent protocol MVP with intent batching and ERC-4337-inspired execution.",
  "workspaces": [
    "contracts",
    "agent",
    "bundler",
    "dashboard",
    "shared"
  ],
  "scripts": {
    "test:contracts": "npm --workspace contracts run test",
    "compile:contracts": "npm --workspace contracts run compile",
    "export:contracts": "npm --workspace shared run export:contracts",
    "dev:agent": "npm --workspace agent run dev",
    "dev:bundler": "npm --workspace bundler run dev",
    "test:flow": "tsx test-flow.ts"
  }
}
